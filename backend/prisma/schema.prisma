// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                   String    @id @default(uuid())
  employeeId           String?   @unique
  email                String    @unique
  password             String
  role                 String    // "Admin", "HR Manager", "Manager", "Employee"
  monthlySalary        Float?
  name                 String
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  deletedAt            DateTime?
  resetPasswordToken   String?   @unique
  resetPasswordExpires DateTime?
  faceEmbedding        String?
  faceEnrolled         Boolean   @default(false)
  faceEnrolledAt       DateTime?
  
  departmentId         String?
  department           Department? @relation(fields: [departmentId], references: [id])

  // Profile extensions
  joinDate             DateTime?
  probationEnd         DateTime?
  emergencyContact     String?
  isRemoteEligible     Boolean   @default(false)
  
  // Hierarchy
  managerId            String?
  manager              User?     @relation("ReportingHierarchy", fields: [managerId], references: [id])
  directReports        User[]    @relation("ReportingHierarchy")

  documents            Document[]
  bankDetails          BankDetail?
  leaveBalances        LeaveBalance[]
  leaveRequests        LeaveRequest[]
  attendanceLogs       AttendanceLog[]
  attendanceCorrections AttendanceCorrection[]
  notifications        Notification[]
  payslips             Payslip[]
  policyAcknowledgements PolicyAcknowledgement[]
  warningLetters       WarningLetter[]
  surveyResponses      SurveyResponse[]
  profileEditRequests  ProfileEditRequest[]
}

model BankDetail {
  id            String    @id @default(uuid())
  userId        String    @unique
  user          User      @relation(fields: [userId], references: [id])
  accountName   String
  accountNumber String
  ifscCode      String
  bankName      String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Document {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  type        String    // e.g., "ID Proof", "Offer Letter", "Medical"
  fileUrl     String    // S3 URL
  uploadedAt  DateTime  @default(now())
}

model LeaveType {
  id             String    @id @default(uuid())
  name           String    // e.g., Casual, Sick, Earned, Emergency
  quota          Int       // Days per year
  carryForward   Boolean   @default(false)
  advanceNotice  Int       @default(0) // Days required in advance
  isEmergency    Boolean   @default(false)
  createdAt      DateTime  @default(now())
  
  balances       LeaveBalance[]
  requests       LeaveRequest[]
}

model LeaveBalance {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  leaveTypeId String
  leaveType   LeaveType @relation(fields: [leaveTypeId], references: [id])
  balance     Float
  year        Int

  @@unique([userId, leaveTypeId, year])
}

model LeaveRequest {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  leaveTypeId String
  leaveType   LeaveType @relation(fields: [leaveTypeId], references: [id])
  startDate   DateTime
  endDate     DateTime
  reason      String
  status      String    @default("Pending") // Pending, Approved, Rejected
  token       String?   @unique // For deep-link approvals
  tokenExpiry DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Department {
  id          String    @id @default(uuid())
  name        String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  users       User[]
}

model Location {
  id          String    @id @default(uuid())
  name        String
  address     String?
  ipRange     String?   // CIDR or IP list e.g. "127.0.0.1, 192.168.1.0/24"
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
}

model OrgSetting {
  id          String    @id @default(uuid())
  key         String    @unique
  value       String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model HolidayCalendar {
  id          String    @id @default(uuid())
  name        String
  date        DateTime
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
}

model AttendanceLog {
  id           String    @id @default(uuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  clockInTime  DateTime
  clockOutTime DateTime?
  workLocation String    // "Office" or "Remote"
  overtime     Boolean   @default(false)
  late         Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  corrections  AttendanceCorrection[]
}

model AttendanceCorrection {
  id               String        @id @default(uuid())
  attendanceLogId  String
  attendanceLog    AttendanceLog @relation(fields: [attendanceLogId], references: [id])
  userId           String
  user             User          @relation(fields: [userId], references: [id])
  requestedClockIn DateTime?
  requestedClockOut DateTime?
  reason           String
  status           String        @default("Pending") // Pending, Approved, Rejected
  note             String?       // HR note
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  content   String
  type      String   // e.g., "leave", "attendance", "document", "probation"
  read      Boolean  @default(false)
  readAt    DateTime?
  createdAt DateTime @default(now())
}

model PayrollRun {
  id          String    @id @default(uuid())
  month       Int       // 1-12
  year        Int
  status      String    @default("Draft") // Draft, Finalized
  createdBy   String
  finalizedBy String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  payslips    Payslip[]
}

model Payslip {
  id           String     @id @default(uuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id])
  payrollRunId String
  payrollRun   PayrollRun @relation(fields: [payrollRunId], references: [id])
  gross        Float
  pf           Float
  esi          Float
  tds          Float
  lop          Float
  net          Float
  fileUrl      String?    // Path or URL to the generated payslip doc
  createdAt    DateTime   @default(now())
}

model Policy {
  id                  String   @id @default(uuid())
  title               String
  fileUrl             String
  readReceiptRequired Boolean  @default(false)
  createdAt           DateTime @default(now())

  acknowledgements    PolicyAcknowledgement[]
}

model PolicyAcknowledgement {
  id        String   @id @default(uuid())
  policyId  String
  policy    Policy   @relation(fields: [policyId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([policyId, userId])
}

model WarningLetter {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String   // Verbal, Written, ShowCause
  content   String
  sentAt    DateTime @default(now())
}

model Announcement {
  id                 String   @id @default(uuid())
  title              String
  content            String   // Rich text content
  targetDepartmentId String?
  fileUrl            String?
  createdAt          DateTime @default(now())
}

model PulseSurvey {
  id        String   @id @default(uuid())
  question  String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  responses SurveyResponse[]
}

model SurveyResponse {
  id            String      @id @default(uuid())
  pulseSurveyId String
  pulseSurvey   PulseSurvey @relation(fields: [pulseSurveyId], references: [id])
  userId        String      // Stored to prevent double voting but anonymized in read aggregations
  user          User        @relation(fields: [userId], references: [id])
  rating        Int         // 1-5 rating or yes/no
  createdAt     DateTime    @default(now())

  @@unique([pulseSurveyId, userId])
}

model ProfileEditRequest {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  field        String   // e.g. "name", "bankDetails.accountNumber", etc.
  oldValue     String
  newValue     String
  reason       String
  status       String   @default("Pending") // Pending, Approved, Rejected
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
